# VastAI API key (https://cloud.vast.ai/cli/)
VAST_API_KEY=your_vast_api_key_here

# Telegram bot token (create via @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# HuggingFace token for faster model downloads (https://huggingface.co/settings/tokens)
HF_TOKEN=your_hf_token_here

# --- Parser / Trend Pipeline ---

# Apify scraping API (https://apify.com/)
APIFY_TOKEN=
TIKTOK_APIFY_ACTOR=
INSTAGRAM_APIFY_ACTOR=

# TikTok custom browser scraping (requires playwright)
TIKTOK_MS_TOKENS=

# Instagram custom scraping (instaloader)
INSTAGRAM_CUSTOM_USERNAME=
INSTAGRAM_CUSTOM_PASSWORD=
INSTAGRAM_CUSTOM_SESSION_FILE=

# yt-dlp cookies for authenticated downloads
YT_DLP_COOKIES_FILE=

# Gemini VLM scoring (https://aistudio.google.com/apikey)
GEMINI_API_KEY=